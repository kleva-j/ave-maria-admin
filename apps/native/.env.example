EXPO_PUBLIC_CONVEX_URL=https://your-convex-url.convex.cloud

# PostHog (product analytics)
EXPO_PUBLIC_POSTHOG_KEY=phc_...
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Novu (in-app notifications) — client. Leave EXPO_PUBLIC_NOVU_APP_ID unset to hide the inbox.
# Application Identifier is public. Secret key lives on the Convex deployment only.
EXPO_PUBLIC_NOVU_APP_ID=your-application-identifier
# EU region only — omit for the default US region.
EXPO_PUBLIC_NOVU_BACKEND_URL=https://eu.api.novu.co
EXPO_PUBLIC_NOVU_SOCKET_URL=https://eu.ws.novu.co

# Sentry — client (runtime). Leave EXPO_PUBLIC_SENTRY_DSN unset or empty to disable Sentry.
EXPO_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
EXPO_PUBLIC_SENTRY_ENVIRONMENT=development
EXPO_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# Sentry — build (source-map upload). Only needed in EAS / prod builds.
# When SENTRY_AUTH_TOKEN is unset or empty the Expo plugin no-ops.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT_NATIVE=avm-daily-native
