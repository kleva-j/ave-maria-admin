VITE_CONVEX_URL="https://your-convex-url.convex.cloud"

WORKOS_CLIENT_ID="client_..."
WORKOS_API_KEY="sk_test_..."
WORKOS_REDIRECT_URI="http://localhost:3001/api/auth/callback"
WORKOS_COOKIE_PASSWORD="use-a-32-char-min-password"
WORKOS_TOTP_ISSUER="..."

# Optional: enable one-click SSO sign-in on the login page
WORKOS_DEFAULT_ORGANIZATION_ID="org_..."

# Upstash (rate limiting)
UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN="..."
AUTH_RATE_LIMIT_MAX="5"
AUTH_RATE_LIMIT_WINDOW_SECONDS="60"

# PostHog (product analytics)
VITE_POSTHOG_KEY="phc_..."
VITE_POSTHOG_HOST="https://us.i.posthog.com"

# Axiom (log aggregation)
AXIOM_DATASET="your-dataset-name"
AXIOM_TOKEN="xaat-..."

# Sentry — client (runtime). Leave VITE_SENTRY_DSN unset to disable Sentry.
VITE_SENTRY_DSN="https://...@sentry.io/..."
VITE_SENTRY_ENVIRONMENT="development"
VITE_SENTRY_TRACES_SAMPLE_RATE="0.1"
# Session Replay: 0% sessions, 100% on error (only buffered when an error fires)
VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE="0"
VITE_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE="1"

# Sentry — build (source-map upload). Only needed in CI/prod builds.
# When SENTRY_AUTH_TOKEN is unset the Vite plugin no-ops.
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT_WEB="avm-daily-web"
SENTRY_RELEASE=""
