VITE_CONVEX_URL="https://your-convex-url.convex.cloud"

WORKOS_CLIENT_ID="client_..."
WORKOS_API_KEY="sk_test_..."
WORKOS_REDIRECT_URI="http://localhost:3001/api/auth/callback"
WORKOS_COOKIE_PASSWORD="use-a-32-char-min-password"
WORKOS_TOTP_ISSUER="..."

# Optional: enable one-click SSO sign-in on the login page
WORKOS_DEFAULT_ORGANIZATION_ID="org_..."

# Upstash (rate limiting)
UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN="..."
AUTH_RATE_LIMIT_MAX="5"
AUTH_RATE_LIMIT_WINDOW_SECONDS="60"

# PostHog (product analytics)
VITE_POSTHOG_KEY="phc_..."
VITE_POSTHOG_HOST="https://us.i.posthog.com"

# Axiom (log aggregation)
AXIOM_DATASET="your-dataset-name"
AXIOM_TOKEN="xaat-..."

# Novu (in-app notifications) — client. Leave VITE_NOVU_APP_ID unset to hide the Inbox.
# Application Identifier is public (safe to ship). The secret key lives on the
# Convex deployment only (npx convex env set NOVU_SECRET_KEY ...), never here.
VITE_NOVU_APP_ID="your-application-identifier"
# EU region only — omit for the default US region.
VITE_NOVU_BACKEND_URL="https://eu.api.novu.co"
VITE_NOVU_SOCKET_URL="https://eu.ws.novu.co"
